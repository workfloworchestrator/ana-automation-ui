# Example environment configuration for ana-automation-ui.
#
# Copy this file to "ana-automation-ui.env" for local development — pydantic-settings
# reads that file automatically. Real environment variables (e.g. those set by the Helm
# chart in-cluster) always take precedence over values in the file.

# --- Server bind ---
HOST=0.0.0.0
PORT=8080

# --- OIDC group names (forwarded by oauth2-proxy as X-Auth-Request-Groups) ---
USERS_GROUP=users
OPERATORS_GROUP=operators

# --- Portal apps config (ConfigMap-mounted JSON in-cluster) ---
APPS_CONFIG_PATH=/config/apps.json

# --- Access-request email feature ---
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=25
SMTP_SECURITY=none            # none | starttls | tls
SMTP_USERNAME=
SMTP_PASSWORD=
ACCESS_REQUEST_RECIPIENT=
ACCESS_REQUEST_FROM=
ACCESS_REQUEST_FROM_USER=false
